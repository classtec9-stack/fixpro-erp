# ================================
# FixPro ERP - Environment Variables
# Copy this to .env and fill values
# ================================

# Server
PORT=3000
NODE_ENV=development

# Database (Supabase)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Email (Resend - free tier)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@fixpro.sa
EMAIL_FROM_NAME=FixPro للصيانة

# File Upload (Supabase Storage)
STORAGE_BUCKET=fixpro-uploads
MAX_FILE_SIZE_MB=10

# WhatsApp (in dev: use manual for free, in prod: Meta Business API)
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# SMS (Unifonic - has free trial)
UNIFONIC_APP_SID=
UNIFONIC_SENDER_ID=FixPro

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
